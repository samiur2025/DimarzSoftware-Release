{
"$schema": "https://schema.tauri.app/config/2",
"productName": "Dimrz",
"version": "1.0.0",
"identifier": "com.dimrz.desktop",
"build": {
"beforeDevCommand": "npm run dev",
"devUrl": "http://localhost:1420",
"beforeBuildCommand": "npm run build",
"frontendDist": "../dist"
},
"app": {
"windows": [
{
"title": "Dimrz - Digital Marketing Zone",
"width": 1440,
"height": 900,
"minWidth": 1024,
"minHeight": 768,
"resizable": true,
"fullscreen": false,
"center": true,
"decorations": true
}
],
"security": {
"csp": "default-src 'self'; connect-src 'self' https://api.dimrz.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; script-src 'self'"
}
},
"bundle": {
"active": true,
"targets": "all",
"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
"windows": {
"certificateThumbprint": null,
"digestAlgorithm": "sha256",
"timestampUrl": "http://timestamp.digicert.com"
}
}
}
